# Example generator: openssl rand -hex 32
# Or just run the command: `echo "SEARXNG_SECRET_KEY=$(openssl rand -hex 32)" >> .env`
SEARXNG_SECRET_KEY=change-me-to-a-long-random-token

SEARXNG_PORT=8080
SEARXNG_BIND_ADDRESS=0.0.0.0
SEARXNG_HOSTNAME=localhost

# Caddy port mappings (Host:Container)
# Map these to available ports on your system (e.g., 8888 and 8443 on Synology)
CADDY_HTTP_PORT=8888
CADDY_HTTPS_PORT=8443
